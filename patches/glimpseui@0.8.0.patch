+    }
+
+    @objc func performFindPrevious(_ sender: Any?) {
+        let js = "if(window.__glimpseFindBar){document.querySelector('#__glimpse-find-bar button:nth-of-type(1)').click()}"
+        webView?.evaluateJavaScript(js, completionHandler: nil)
+    }
