+    // When running as accessory (noDock) or frameless, macOS skips normal
+    // menu key-equivalent routing. Fall back to the responder chain so
+    // copy/paste/undo/redo etc. still work.
+    override func performKeyEquivalent(with event: NSEvent) -> Bool {
+        if super.performKeyEquivalent(with: event) {
+            return true
+        }
+        if NSApp.mainMenu?.performKeyEquivalent(with: event) == true {
+            return true
+        }
+
+        let modifiers = event.modifierFlags.intersection(.deviceIndependentFlagsMask)
+        guard modifiers == .command || modifiers == [.command, .shift] else {
+            return false
+        }
+        guard let chars = event.charactersIgnoringModifiers?.lowercased() else {
+            return false
+        }
+
+        let action: Selector?
+        switch chars {
+        case "c": action = #selector(NSText.copy(_:))
+        case "x": action = #selector(NSText.cut(_:))
+        case "v": action = #selector(NSText.paste(_:))
+        case "a": action = #selector(NSText.selectAll(_:))
+        case "z":
+            action = modifiers == [.command, .shift] ? Selector(("redo:")) : Selector(("undo:"))
+        default: action = nil
+        }
+
+        guard let action else { return false }
+        return NSApp.sendAction(action, to: nil, from: self)
+    }
 }
 
