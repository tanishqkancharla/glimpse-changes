+    @objc func toggleDeveloperTools(_ sender: Any?) {
+        // WKWebView exposes the inspector via private API — use the same approach
+        // Safari and many Electron-like apps use. The key is _inspector.
+        guard let webView = webView else { return }
+        if webView.responds(to: Selector(("_inspector"))) {
+            if let inspector = webView.value(forKey: "_inspector") as? NSObject {
+                if inspector.responds(to: Selector(("isVisible"))) {
+                    let isVisible = inspector.value(forKey: "isVisible") as? Bool ?? false
+                    if isVisible {
+                        inspector.perform(Selector(("close")))
+                    } else {
+                        inspector.perform(Selector(("show")))
+                    }
+                } else {
+                    inspector.perform(Selector(("show")))
+                }
+            }
+        }
+    }
