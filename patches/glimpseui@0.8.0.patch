+    @objc func performFindAction(_ sender: Any?) {
+        // Inject a JavaScript-based find UI into the webview
+        let findJS = """
+        (function() {
+            if (window.__glimpseFindBar) {
+                window.__glimpseFindBar.toggle();
+                return;
+            }
+
+            const bar = document.createElement('div');
+            bar.id = '__glimpse-find-bar';
+            bar.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:999999;display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--panel,#f5f5f0);border-bottom:1px solid var(--border,#d0d0c8);font-family:system-ui;font-size:13px;box-shadow:0 2px 8px rgba(0,0,0,0.1);';
+
+            const input = document.createElement('input');
+            input.type = 'text';
+            input.placeholder = 'Find in page…';
+            input.style.cssText = 'flex:1;padding:4px 8px;border:1px solid var(--border,#ccc);border-radius:4px;font-size:13px;background:var(--bg,#fff);color:var(--text,#000);outline:none;';
+
+            const info = document.createElement('span');
+            info.style.cssText = 'color:var(--muted,#999);font-size:12px;min-width:60px;text-align:center;';
+
+            const btnStyle = 'padding:4px 8px;border:1px solid var(--border,#ccc);border-radius:4px;background:var(--bg,#fff);color:var(--text,#000);cursor:pointer;font-size:12px;';
+
+            const prevBtn = document.createElement('button');
+            prevBtn.textContent = '▲';
+            prevBtn.style.cssText = btnStyle;
+
+            const nextBtn = document.createElement('button');
+            nextBtn.textContent = '▼';
+            nextBtn.style.cssText = btnStyle;
+
+            const closeBtn = document.createElement('button');
+            closeBtn.textContent = '✕';
+            closeBtn.style.cssText = btnStyle;
+
+            bar.append(input, info, prevBtn, nextBtn, closeBtn);
+            document.body.prepend(bar);
+
+            let matches = [];
+            let currentIdx = -1;
+            let highlights = [];
+
+            function clearHighlights() {
+                highlights.forEach(h => {
+                    const parent = h.parentNode;
+                    if (parent) {
+                        parent.replaceChild(document.createTextNode(h.textContent), h);
+                        parent.normalize();
+                    }
+                });
+                highlights = [];
+                matches = [];
+                currentIdx = -1;
+            }
+
+            function highlightMatches(query) {
+                clearHighlights();
+                if (!query) { info.textContent = ''; return; }
+                const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
+                    acceptNode: (node) => {
+                        let el = node.parentElement;
+                        while (el) {
+                            if (el.id === '__glimpse-find-bar') return NodeFilter.FILTER_REJECT;
+                            el = el.parentElement;
+                        }
+                        return NodeFilter.FILTER_ACCEPT;
+                    }
+                });
+                const textNodes = [];
+                while (walker.nextNode()) textNodes.push(walker.currentNode);
+                const lowerQuery = query.toLowerCase();
+                for (const node of textNodes) {
+                    const text = node.textContent;
+                    const lower = text.toLowerCase();
+                    let idx = lower.indexOf(lowerQuery);
+                    if (idx === -1) continue;
+                    const frag = document.createDocumentFragment();
+                    let lastIdx = 0;
+                    while (idx !== -1) {
+                        frag.appendChild(document.createTextNode(text.slice(lastIdx, idx)));
+                        const mark = document.createElement('mark');
+                        mark.style.cssText = 'background:#ffeb3b;color:#000;border-radius:2px;padding:0 1px;';
+                        mark.textContent = text.slice(idx, idx + query.length);
+                        frag.appendChild(mark);
+                        highlights.push(mark);
+                        lastIdx = idx + query.length;
+                        idx = lower.indexOf(lowerQuery, lastIdx);
+                    }
+                    frag.appendChild(document.createTextNode(text.slice(lastIdx)));
+                    node.parentNode.replaceChild(frag, node);
+                }
+                matches = highlights.slice();
+                if (matches.length > 0) {
+                    currentIdx = 0;
+                    focusCurrent();
+                }
+                updateInfo();
+            }
+
+            function focusCurrent() {
+                matches.forEach((m, i) => {
+                    m.style.background = i === currentIdx ? '#ff9800' : '#ffeb3b';
+                });
+                if (matches[currentIdx]) {
+                    matches[currentIdx].scrollIntoView({ behavior: 'smooth', block: 'center' });
+                }
+            }
+
+            function updateInfo() {
+                info.textContent = matches.length > 0 ? `${currentIdx + 1} of ${matches.length}` : (input.value ? 'No results' : '');
+            }
+
+            function goNext() {
+                if (matches.length === 0) return;
+                currentIdx = (currentIdx + 1) % matches.length;
+                focusCurrent(); updateInfo();
+            }
+
+            function goPrev() {
+                if (matches.length === 0) return;
+                currentIdx = (currentIdx - 1 + matches.length) % matches.length;
+                focusCurrent(); updateInfo();
+            }
+
+            function hide() {
+                clearHighlights();
+                bar.style.display = 'none';
+            }
+
+            let debounce;
+            input.addEventListener('input', () => {
+                clearTimeout(debounce);
+                debounce = setTimeout(() => highlightMatches(input.value), 150);
+            });
+            input.addEventListener('keydown', (e) => {
+                if (e.key === 'Escape') { hide(); e.preventDefault(); }
+                if (e.key === 'Enter' && !e.shiftKey) { goNext(); e.preventDefault(); }
+                if (e.key === 'Enter' && e.shiftKey) { goPrev(); e.preventDefault(); }
+            });
+            nextBtn.addEventListener('click', goNext);
+            prevBtn.addEventListener('click', goPrev);
+            closeBtn.addEventListener('click', hide);
+
+            window.__glimpseFindBar = {
+                toggle: () => {
+                    if (bar.style.display === 'none') {
+                        bar.style.display = 'flex';
+                        input.focus();
+                        input.select();
+                    } else {
+                        hide();
+                    }
+                }
+            };
+            input.focus();
+        })();
+        """
+        webView?.evaluateJavaScript(findJS, completionHandler: nil)
+    }
+
