{
  "name": "glimpse-changes",
  "version": "1.9.1",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "bin": {
    "glimpse-changes": "bin/glimpse-changes.js"
  },
  "files": [
    "bin",
    "assets",
    "skills"
  ],
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "bun build scripts/render-md.ts --target=node --outfile=bin/glimpse-changes.js --external glimpseui && sed -i '' '1s|.*|#!/usr/bin/env node|' bin/glimpse-changes.js",
    "test": "vitest run"
  },
  "dependencies": {
    "glimpseui": "^0.8.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
